{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus Launcher",
  "version": "1.0.0",
  "identifier": "xyz.centralchamados.launcher-mac-silicon",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node build-frontend.cjs",
    "beforeBuildCommand": "node build-frontend.cjs"
  },
  "app": {
    "windows": [
      {
        "title": "Nexus Launcher",
        "width": 980,
        "height": 700,
        "minWidth": 820,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://map.centralchamados.xyz data:; connect-src 'self' ipc: http://ipc.localhost; frame-src 'self' https://map.centralchamados.xyz; child-src 'self' https://map.centralchamados.xyz; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {}
}
