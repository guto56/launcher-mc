{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Launcher MC Silicon",
  "version": "1.0.0",
  "identifier": "xyz.centralchamados.launcher-mac-silicon",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node build-frontend.cjs",
    "beforeBuildCommand": "node build-frontend.cjs"
  },
  "app": {
    "windows": [
      {
        "title": "Launcher MC Silicon",
        "width": 980,
        "height": 700,
        "minWidth": 820,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {}
}
