{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Launcher MC",
  "version": "1.0.0",
  "identifier": "xyz.centralchamados.launchermc",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node build-frontend.cjs",
    "beforeBuildCommand": "node build-frontend.cjs"
  },
  "app": {
    "windows": [
      {
        "title": "Launcher MC — painel-mc",
        "width": 1100,
        "height": 760,
        "minWidth": 820,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "pt-BR"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {}
}
