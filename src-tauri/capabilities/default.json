{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "launcher-mc:default",
  "description": "Capacidades padrão do Launcher MC (comandos locais + diálogo).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "launcher_mc:allow-detect-mods-dir",
    "launcher_mc:allow-list-local-mods",
    "launcher_mc:allow-save-mod",
    "launcher_mc:allow-open-minecraft-folder",
    "launcher_mc:allow-download-mod",
    "launcher_mc:allow-base-url"
  ]
}
